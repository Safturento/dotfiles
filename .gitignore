# Font binaries — too big for git, extracted from zips on-demand by install.sh.
# Use ** so the patterns also match extracted families in fonts/<name>/ subdirs.
fonts

# Local-only overrides (kept out of the public repo)
*.local
*.local.*

# OS / editor cruft
.DS_Store
*~
*.swp

# Reminder check-in throttle state (machine-local, transient)
claude/reminders/.state/
